<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" id="WebApp_ID" version="6.0">
    <display-name>StudentApp</display-name>


    <!-- StudentServlet (insert student into DB) -->
    <servlet>
        <servlet-name>StudentServlet</servlet-name>
        <servlet-class>com.Serv.StudentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/addStudent</url-pattern>
    </servlet-mapping>

    <!-- ViewStudentsServlet (list students) -->
    <servlet>
        <servlet-name>ViewStudentsServlet</servlet-name>
        <servlet-class>com.Serv.ViewStudentsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewStudentsServlet</servlet-name>
        <url-pattern>/viewStudents</url-pattern>
    </servlet-mapping>

    <!-- Welcome file -->
    <welcome-file-list>
        <welcome-file>studentForm.html</welcome-file>
    </welcome-file-list>

</web-app>
